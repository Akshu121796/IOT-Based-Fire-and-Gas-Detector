// Copy this file, rename the copy to "secrets.h", and fill in your own values.
// Both arduino_code.ino and esp32code.ino include this same file.

#ifndef SECRETS_H
#define SECRETS_H

// --- used by arduino_code.ino ---
const char* phoneNumber = "+91XXXXXXXXXX"; // phone number to receive SMS alerts

// --- used by esp32code.ino ---
const char* ssid = "your_wifi_name";
const char* password = "your_wifi_password";
unsigned long channelID = 0000000;           // your ThingSpeak channel ID
const char* writeAPI = "YOUR_WRITE_API_KEY"; // your ThingSpeak Write API Key

#endif
